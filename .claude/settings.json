{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "EDITOR": "nvim"
  },
  "permissions": {
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(rm -rf /*)",
      "Bash(sudo:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)"
    ],
    "ask": [
      "Bash(rm:*)",
      "Bash(git push:*)",
      "Bash(git commit:*)"
    ],
    "defaultMode": "default"
  },
  "theme": "dark",
  "editorMode": "vim",
  "autoCompact": true,
  "checkpoints": true,
  "showTips": true,
  "agentPushNotifEnabled": false
}
