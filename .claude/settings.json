{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "EDITOR": "nvim"
  },
  "permissions": {
    "deny": [
      "Bash(sudo:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)"
    ],
    "ask": [
      "Bash(rm:*)",
      "Bash(git push:*)",
      "Bash(git commit:*)"
    ],
    "defaultMode": "default"
  },
  "model": "opus[1m]",
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/tmux-attention.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/tmux-attention.sh"
          }
        ]
      }
    ]
  },
  "effortLevel": "xhigh",
  "skipWorkflowUsageWarning": false,
  "theme": "dark",
  "editorMode": "vim",
  "agentPushNotifEnabled": false,
  "skipAutoPermissionPrompt": true,
  "autoCompact": true,
  "checkpoints": true,
  "showTips": true
}
